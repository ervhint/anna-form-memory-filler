{
  "name": "anna-form-document-parser-ervhint",
  "version": "0.1.3",
  "description": "Tool Executa for parsing target forms and source documents into structured evidence JSON for Form Memory Filler.",
  "type": "commonjs",
  "main": "src/main.js",
  "bin": {
    "form-document-parser": "src/main.js"
  },
  "scripts": {
    "start": "node src/main.js",
    "dev": "node src/main.js",
    "build:binary": "npm run build:binary:win && npm run build:binary:linux && npm run build:binary:macos-x64 && npm run build:binary:macos-arm64",
    "build:binary:win": "node node_modules/pkg/lib-es5/bin.js src/main.js --targets node18-win-x64 --output dist/form-document-parser-windows-x64.exe",
    "build:binary:linux": "node node_modules/pkg/lib-es5/bin.js src/main.js --targets node18-linux-x64 --output dist/form-document-parser-linux-x64",
    "build:binary:macos-x64": "node node_modules/pkg/lib-es5/bin.js src/main.js --targets node18-macos-x64 --output dist/form-document-parser-macos-x64",
    "build:binary:macos-arm64": "node node_modules/pkg/lib-es5/bin.js src/main.js --targets node18-macos-arm64 --output dist/form-document-parser-macos-arm64"
  },
  "keywords": [
    "anna",
    "executa",
    "form-memory-filler",
    "document-parser",
    "docx"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "mammoth": "^1.8.0"
  },
  "files": [
    "src",
    "executa.json"
  ],
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
