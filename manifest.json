        "required:bundled:form-document-parser"
      ],
      "chat": [],
      "artifact": [],
      "llm": [],
      "fs": [],
      "storage": [],
      "prefs": [],
      "window": [
        "set_title"
      ]
    },
    "csp_overrides": {
      "img-src": [
        "'self'",
        "data:",
        "blob:"
      ],
      "font-src": [
        "'self'",
        "data:"
      ],
      "style-src": [
        "'self'"
      ],
      "script-src": [
        "'self'"
      ]
    },
    "state_merge": "last_writer_wins"
  }
}
