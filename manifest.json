{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:form-memory-store",
      "version": "latest"
    },
    {
      "tool_id": "skill-ervhint-form-memory-filler-skill-x82q5eb6",
      "version": "latest"
    },
    {
      "tool_id": "bundled:form-document-parser",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Form Memory Filler",
        "default": true,
        "entry": "index.html",
        "min_size": {
          "w": 360,
          "h": 520
        },
        "default_size": {
          "w": 900,
          "h": 720
        },
        "max_size": {
          "w": 1200,
          "h": 960
